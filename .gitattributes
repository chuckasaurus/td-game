# Normalize all text files to LF in the repo; check out as LF on every OS.
# This eliminates "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Source / text files (explicit, in case auto-detection misses one)
*.gd            text eol=lf
*.cs            text eol=lf
*.tscn          text eol=lf
*.tres          text eol=lf
*.cfg           text eol=lf
*.import        text eol=lf
*.gdshader      text eol=lf
*.gdshaderinc   text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.svg           text eol=lf
*.uid           text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
project.godot   text eol=lf

# Binary asset formats (never line-ending-converted, never text-diffed)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.gif      binary
*.ico      binary
*.bmp      binary
*.tga      binary
*.exr      binary
*.hdr      binary

*.wav      binary
*.ogg      binary
*.mp3      binary
*.flac     binary

*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary

*.glb      binary
*.gltf     binary
*.fbx      binary
*.obj      binary
*.blend    binary

*.psd      binary
*.aseprite binary
*.kra      binary
*.xcf      binary

*.zip      binary
*.7z       binary
